# Banco de Dados
DB_NAME=rsvp_db
DB_USER=root
DB_PASSWORD=
DB_HOST=db

# Flask
SECRET_KEY=

# Opcionais
TZ_OFFSET_HOURS=-3
LOG_FILE=logs/app.log
UPLOAD_FOLDER=static/uploads

# Email (SMTP) — necessário para verificação de email e reset de senha
# Use Brevo (300/dia grátis) ou Resend (3000/mês grátis) — evite Gmail App Password em produção
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORTA=587
EMAIL_USER=seu@email.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Bypass de verificação de email (SOMENTE DEV — default OFF em produção)
# SKIP_EMAIL_VERIFICATION=1

# URL base da aplicação (usada nos links de email)
APP_BASE_URL=https://seu-dominio.com

# Backup automático (container backup)
BACKUP_RETENTION_DAYS=7   # dias para manter — backups mais antigos são apagados automaticamente
