# Banco de Dados
DB_NAME=rsvp_db
DB_USER=root
DB_PASSWORD=
DB_HOST=db

# Flask
SECRET_KEY=

# Opcionais
TZ_OFFSET_HOURS=-3
LOG_FILE=logs/app.log
UPLOAD_FOLDER=/app/uploads   # volume nomeado Docker; em dev local use static/uploads

# ── Email transacional — escolha UM provedor (comente os demais) ─────────────
#
# Opção 1: Brevo (recomendado) — 300 emails/dia grátis, SMTP puro, sem SDK
# EMAIL_SMTP=smtp-relay.brevo.com
# EMAIL_PORTA=587
# EMAIL_USER=seu-login-cadastrado@dominio.com   # e-mail de cadastro na Brevo
# EMAIL_PASS=xSMTP-KEY-GERADA-NO-DASHBOARD      # Brevo > Configurações > SMTP e API
#
# Opção 2: Resend — 3 000 emails/mês grátis (≈ 100/dia), SMTP puro, sem SDK
# EMAIL_SMTP=smtp.resend.com
# EMAIL_PORTA=587
# EMAIL_USER=resend                              # literal "resend" — não é seu e-mail
# EMAIL_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx     # Resend > API Keys
#
# Opção 3: Gmail App Password — somente dev local, não usar em produção
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORTA=587
EMAIL_USER=seu@email.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Bypass de verificação de email (SOMENTE DEV — default OFF em produção)
# SKIP_EMAIL_VERIFICATION=1

# URL base da aplicação (usada nos links de email)
APP_BASE_URL=https://seu-dominio.com

# Fila Redis + RQ (email assíncrono)
# Ausente → dev sem fila (executa síncrono com warning)
# Presente mas Redis offline → produção loga erro, NÃO executa síncrono
REDIS_URL=redis://redis:6379/0

# Backup automático (container backup)
BACKUP_RETENTION_DAYS=7   # dias para manter — backups mais antigos são apagados automaticamente

# Super-admin do SaaS — acessa /superadmin para gerenciar tenants
# ATENÇÃO: este email NÃO deve existir como conta de tenant no banco.
# Use um email dedicado que nunca tenha sido cadastrado via signup.
# Se o email pertencer a um tenant_admin, o acesso será bloqueado (config inválida).
# SUPERADMIN_EMAIL=admin@seudominio.com
